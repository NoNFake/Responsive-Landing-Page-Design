/* Fonts Module */

:root {
    /* Fonts | Size*/
    --font-family-primary: 'Inter', sans-serif;

    /* Desktop */
    @media screen and (max-width: 1440px) {

        /* Header */
        /* 600 */
        --font-size-xl-desk: 64px;
        --font-size-lg-desk: 36px;
        --font-size-nd-desk: 28px;
        --font-size-sn-desk: 20px;
      
        --font-size-xl-height: 76px;
        --font-size-lg-height: 44px;
        --font-size-nd-height: 36px;
        --font-size-sn-height: 28px;
      
      
        --font-size-xl-mob: 69px;
        --font-size-lg-mob: 40px;
        --font-size-nd-mob: 34px;
        --font-size-sn-mob: 26px;
      
        --font-weight-h-desk: 600;

        /* .h1 { font-size: clamp(var(--font-size-xl-mob), 5vw, var(--font-size-xl-desk)); line-height: var(--font-size-xl-height); font-weight: 600;} */
        .h1 { font-size: var(--font-size-xl-desk); line-height: var(--font-size-xl-height); font-weight: var(--font-weight-h-desk);}
        .h2 { font-size: var(--font-size-lg-desk); line-height: var(--font-size-lg-height); font-weight: var(--font-weight-h-desk);}
        .h3 { font-size: var(--font-size-nd-desk); line-height: var(--font-size-nd-height); font-weight: var(--font-weight-h-desk);}
        .h4 { font-size: var(--font-size-sn-desk); line-height: var(--font-size-sn-height); font-weight: var(--font-weight-h-desk);}
        

        /* Body */
        /* Regular*/
        /* 400 */
        --font-size-xl-rg-desk:   18px;
        --font-size-lg-rg-desk:   16px;
        --font-size-nd-rg-desk:   14px;
        --font-size-sn-rg-desk:   12px;

        --font-size-xl-rg-height:  28px;
        --font-size-lg-rg-height:  24px;
        --font-size-nd-rg-height:  20px;
        --font-size-sn-rg-height:  16px;

        --font-weight-rg-desk: 400;

        
        /* .body-regular-1 { font-size: clamp(var(--font-size-xl-rg-min), 5vw, var(--font-size-xl-rg-desk)); font-weight: 400;}
        .body-regular-2 { font-size: clamp(var(--font-size-lg-rg-min), 5vw, var(--font-size-lg-rg-desk));  font-weight: 400;}
        .body-regular-3 { font-size: clamp(var(--font-size-nd-rg-min), 5vw, var(--font-size-nd-rg-desk));  font-weight: 400;}
        .body-regular-4 { font-size: clamp(var(--font-size-sn-rg-min), 5vw, var(--font-size-sn-rg-desk));  font-weight: 400;} */
        .bd-rg-1 { font-size: var(--font-size-xl-rg-desk); line-height: var(--font-size-xl-rg-height); font-weight: var(--font-weight-rg-desk);}
        .bd-rg-2 { font-size: var(--font-size-lg-rg-desk); line-height: var(--font-size-lg-rg-height); font-weight: var(--font-weight-rg-desk);}
        .bd-rg-3 { font-size: var(--font-size-nd-rg-desk); line-height: var(--font-size-nd-rg-height); font-weight: var(--font-weight-rg-desk);}
        .bd-rg-4 { font-size: var(--font-size-sn-rg-desk); line-height: var(--font-size-sn-rg-height); font-weight: var(--font-weight-rg-desk);}
        
        /* Medium */
        /* 500 */
        --font-weight-rg-md-desk: 500;
        .bd-rg-md-1 { font-size: var(--font-size-xl-rg-desk); line-height: var(--font-size-xl-rg-height); font-weight: var(--font-weight-rg-md-desk);}
        .bd-rg-md-2 { font-size: var(--font-size-lg-rg-desk); line-height: var(--font-size-lg-rg-height); font-weight: var(--font-weight-rg-md-desk);}
        .bd-rg-md-3 { font-size: var(--font-size-nd-rg-desk); line-height: var(--font-size-nd-rg-height); font-weight: var(--font-weight-rg-md-desk);}
        .bd-rg-md-4 { font-size: var(--font-size-sn-rg-desk); line-height: var(--font-size-sn-rg-height); font-weight: var(--font-weight-rg-md-desk);}
    }


    /* Laptop */
    @media screen and (max-width: 1240px) {

      /* Header */
      /* 600 */
      --font-size-xl-lapt: 54px;
      --font-size-lg-lapt: 26px;
      --font-size-nd-lapt: 18px;
      --font-size-sn-lapt: 10px;

      --font-size-xl-height: 66px;
      --font-size-lg-height: 34px;
      --font-size-nd-height: 26px;
      --font-size-sn-height: 18px;


      --font-weight-h-lapt: 600;

      /* .h1 { font-size: clamp(var(--font-size-xl-mob), 5vw, var(--font-size-xl-desk)); line-height: var(--font-size-xl-height); font-weight: 600;} */
      .h1 {
        font-size: var(--font-size-xl-lapt);
        line-height: var(--font-size-xl-height);
        font-weight: var(--font-weight-h-lapt);
      }

      .h2 {
        font-size: var(--font-size-lg-lapt);
        line-height: var(--font-size-lg-height);
        font-weight: var(--font-weight-h-lapt);
      }

      .h3 {
        font-size: var(--font-size-nd-lapt);
        line-height: var(--font-size-nd-height);
        font-weight: var(--font-weight-h-lapt);
      }

      .h4 {
        font-size: var(--font-size-sn-lapt);
        line-height: var(--font-size-sn-height);
        font-weight: var(--font-weight-h-lapt);
      }


      /* Body */
      /* Regular*/
      /* 400 */
      --font-size-xl-rg-lapt: 16px;
      --font-size-lg-rg-lapt: 14px;
      --font-size-nd-rg-lapt: 12px;
      --font-size-sn-rg-lapt: 10px;

      --font-size-xl-rg-height: 28px;
      --font-size-lg-rg-height: 24px;
      --font-size-nd-rg-height: 20px;
      --font-size-sn-rg-height: 16px;

      --font-weight-rg-lapt: 400;


      /* .body-regular-1 { font-size: clamp(var(--font-size-xl-rg-min), 5vw, var(--font-size-xl-rg-desk)); font-weight: 400;}
        .body-regular-2 { font-size: clamp(var(--font-size-lg-rg-min), 5vw, var(--font-size-lg-rg-desk));  font-weight: 400;}
        .body-regular-3 { font-size: clamp(var(--font-size-nd-rg-min), 5vw, var(--font-size-nd-rg-desk));  font-weight: 400;}
        .body-regular-4 { font-size: clamp(var(--font-size-sn-rg-min), 5vw, var(--font-size-sn-rg-desk));  font-weight: 400;} */
      .bd-rg-1 {
        font-size: var(--font-size-xl-rg-lapt);
        line-height: var(--font-size-xl-rg-height);
        font-weight: var(--font-weight-rg-lapt);
      }

      .bd-rg-2 {
        font-size: var(--font-size-lg-rg-lapt);
        line-height: var(--font-size-lg-rg-height);
        font-weight: var(--font-weight-rg-lapt);
      }

      .bd-rg-3 {
        font-size: var(--font-size-nd-rg-lapt);
        line-height: var(--font-size-nd-rg-height);
        font-weight: var(--font-weight-rg-lapt);
      }

      .bd-rg-4 {
        font-size: var(--font-size-sn-rg-lapt);
        line-height: var(--font-size-sn-rg-height);
        font-weight: var(--font-weight-rg-lapt);
      }

      /* Medium */
      /* 500 */
      --font-weight-rg-md-lapt: 500;

      .bd-rg-md-1 {
        font-size: var(--font-size-xl-rg-lapt);
        line-height: var(--font-size-xl-rg-height);
        font-weight: var(--font-weight-rg-md-lapt);
      }

      .bd-rg-md-2 {
        font-size: var(--font-size-lg-rg-lapt);
        line-height: var(--font-size-lg-rg-height);
        font-weight: var(--font-weight-rg-md-lapt);
      }

      .bd-rg-md-3 {
        font-size: var(--font-size-nd-rg-lapt);
        line-height: var(--font-size-nd-rg-height);
        font-weight: var(--font-weight-rg-md-lapt);
      }

      .bd-rg-md-4 {
        font-size: var(--font-size-sn-rg-lapt);
        line-height: var(--font-size-sn-rg-height);
        font-weight: var(--font-weight-rg-md-lapt);
      }
    }

        /* Mobile */
    @media screen and (max-width: 786px) {

      /* Header */
      /* 600 */
      --font-size-xl-mob: 44px;
      --font-size-lg-mob: 16px;
      --font-size-nd-mob: 8px;
      --font-size-sn-mob: 6px;

      --font-size-xl-height: 46px;
      --font-size-lg-height: 24px;
      --font-size-nd-height: 16px;
      --font-size-sn-height: 12px;


      --font-weight-h-mob: 600;

      /* .h1 { font-size: clamp(var(--font-size-xl-mob), 5vw, var(--font-size-xl-desk)); line-height: var(--font-size-xl-height); font-weight: 600;} */
      .h1 {
        font-size: var(--font-size-xl-mob);
        line-height: var(--font-size-xl-height);
        font-weight: var(--font-weight-h-mob);
      }

      .h2 {
        font-size: var(--font-size-lg-mob);
        line-height: var(--font-size-lg-height);
        font-weight: var(--font-weight-h-mob);
      }

      .h3 {
        font-size: var(--font-size-nd-mob);
        line-height: var(--font-size-nd-height);
        font-weight: var(--font-weight-h-mob);
      }

      .h4 {
        font-size: var(--font-size-sn-mob);
        line-height: var(--font-size-sn-height);
        font-weight: var(--font-weight-h-mob);
      }


      /* Body */
      /* Regular*/
      /* 400 */
      --font-size-xl-rg-mob: 14px;
      --font-size-lg-rg-mob: 12px;
      --font-size-nd-rg-mob: 10px;
      --font-size-sn-rg-mob: 8px;

      --font-size-xl-rg-height: 18px;
      --font-size-lg-rg-height: 14px;
      --font-size-nd-rg-height: 10px;
      --font-size-sn-rg-height: 8px;

      --font-weight-rg-lapt: 400;


      /* .body-regular-1 { font-size: clamp(var(--font-size-xl-rg-min), 5vw, var(--font-size-xl-rg-desk)); font-weight: 400;}
        .body-regular-2 { font-size: clamp(var(--font-size-lg-rg-min), 5vw, var(--font-size-lg-rg-desk));  font-weight: 400;}
        .body-regular-3 { font-size: clamp(var(--font-size-nd-rg-min), 5vw, var(--font-size-nd-rg-desk));  font-weight: 400;}
        .body-regular-4 { font-size: clamp(var(--font-size-sn-rg-min), 5vw, var(--font-size-sn-rg-desk));  font-weight: 400;} */
      .bd-rg-1 {
        font-size: var(--font-size-xl-rg-mob);
        line-height: var(--font-size-xl-rg-height);
        font-weight: var(--font-weight-rg-mob);
      }

      .bd-rg-2 {
        font-size: var(--font-size-lg-rg-mob);
        line-height: var(--font-size-lg-rg-height);
        font-weight: var(--font-weight-rg-mob);
      }

      .bd-rg-3 {
        font-size: var(--font-size-nd-rg-mob);
        line-height: var(--font-size-nd-rg-height);
        font-weight: var(--font-weight-rg-mob);
      }

      .bd-rg-4 {
        font-size: var(--font-size-sn-rg-mob);
        line-height: var(--font-size-sn-rg-height);
        font-weight: var(--font-weight-rg-mob);
      }

      /* Medium */
      /* 500 */
      --font-weight-rg-md-lapt: 500;

      .bd-rg-md-1 {
        font-size: var(--font-size-xl-rg-mob);
        line-height: var(--font-size-xl-rg-height);
        font-weight: var(--font-weight-rg-md-mob);
      }

      .bd-rg-md-2 {
        font-size: var(--font-size-lg-rg-mob);
        line-height: var(--font-size-lg-rg-height);
        font-weight: var(--font-weight-rg-md-mob);
      }

      .bd-rg-md-3 {
        font-size: var(--font-size-nd-rg-mob);
        line-height: var(--font-size-nd-rg-height);
        font-weight: var(--font-weight-rg-md-mob);
      }

      .bd-rg-md-4 {
        font-size: var(--font-size-sn-rg-mob);
        line-height: var(--font-size-sn-rg-height);
        font-weight: var(--font-weight-rg-md-mob);
      }
    }



    /* Font Size */
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      margin: 0;
      font-weight: 600;
    }
  
    /* h1,
    .h1 {
      font-size: var(--font-size-xl-desk);
        line-height: var(--font-size-xl-height);
        font-weight: 600;
      color: var(--color-d_grey);
    }
  
    h2 {
      font-size: var(--font-size-lg-desk);
        line-height: var(--font-size-lg-height);
        font-weight: 600;
      color: var(--color-d_grey);
    }
  
    h3 {
      font-size: var(--font-size-nd-desk);
        line-height: var(--font-size-nd-height);
        font-weight: 600;
      color: var(--color-d_grey);
    }
  
    h4 {
      font-size: var(--font-size-sn-desk);
        line-height: var(--font-size-sn-height);
        font-weight: 600;
      color: var(--color-d_grey);
    }
  
    */

     p {
      margin: 0;
      padding: 0;
      line-height: 24px;
      /* color: var(--color-grey); */
    }

    .font-white {
      color: var(--color-white);
    }

    .font-black {
      color: var(--color-black);
    }
        /*
    a {
        font-weight: 500;
        /* line-height: 17px; 
        font-size: var(--font-size-p-nd-rg);
    } */
  }
