@import url('./fonts.css');


.btn {
    
    --btn-display: inline-flex;
    --btn-base-font-size: var(--font-size-p-sn-rg, 11px);
    /* --btn-base-font-size: 12px; */
    --btn-base-text-color: var(--color-text, #ffffff);
    --btn-base-background-color: var(--color-primary, #4CAF4F);
    --btn-border-radius: 6px;

    box-sizing: border-box;
    display: var(--btn-display);
    
    flex-direction: row;
    justify-content: center;
    font-size: var(--btn-base-font-size);
    background-color: var(--btn-base-background-color);
    color: var(--btn-base-text-color);
    border-radius: var(--btn-border-radius);
    text-decoration: none;
    cursor: pointer;
    padding: 10px 23px;
    align-items: center;

    /* width: 89px;
    height: 36px; */
    gap: 8px;

    /* &.arrow {
        width: 133px;
        height: 36px;
    }
    */
    &.arrow:hover {
        padding: 10px 26px;
    } 
}


/* Header */

/* Log in */
.btn__header-login {
    display: flex;
    flex-direction: row;

    background: transparent;
    padding: 10px 20px;
    color: var(--color-primary);
}


/* Sign up */
.btn__header-signup {
    --btn-border-signup-radius: 6px;
    border-radius: var(--btn-border-signup-radius);
    display: flex;
    flex-direction: row;

    background: var(--color-primary);
    padding: 10px 20px;
    color: var(--color-white);
}



/* Hero */



.btn--readmore {
    display: var(--btn-display);
    font-size: var(--btn-base-font-size);

    background-color: transparent;
    color: var(--color-primary);
    padding: 5.9px 6px;
    box-sizing: border-box;
    text-decoration: none;
    cursor: pointer;
  
    font-size: 14px;
    font-weight: 600;
}
.btn--readmore:hover{
    padding: 5.9px 8px; 
}






.btn:hover {
    filter: drop-shadow(0px 4px 4px #c0c0c0);
    /* box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);  */
}


.btn-tertiary {
    color: var(--color-primary);
    display: var(--btn-display);
    font-size: var(--btn-base-font-size);
    
    padding: 8px 24px ;
    box-sizing: border-box;
    text-decoration: none;
    cursor: pointer;

    font-size: 14px;
    font-weight: 600;
    
    /* transition: 0.3s ease; */
}

.btn-tertiary:hover {
    /* background-color: var(--color-silver); */
    background-color: transparent;
    padding: 8px 29px;
    filter: drop-shadow(0px 4px 4px #c0c0c0);
}
